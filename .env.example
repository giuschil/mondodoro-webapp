# ============================================================
# ListDreams — Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================


# ── Django ────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-ME-IN-PRODUCTION

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=listdreams.it,www.listdreams.it,localhost,127.0.0.1


# ── Database ───────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://mondodoro_user:strongpassword@localhost:5432/mondodoro


# ── Redis / Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0


# ── Stripe ─────────────────────────────────────────────────────
# Use pk_test_ / sk_test_ for staging, pk_live_ / sk_live_ for production
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE

# Get this from the Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE


# ── URLs ───────────────────────────────────────────────────────
BASE_URL=https://www.listdreams.it
FRONTEND_URL=https://www.listdreams.it


# ── Email (SMTP) ───────────────────────────────────────────────
# In development you can use the console backend (prints to terminal):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# In production use SMTP:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@listdreams.it
EMAIL_HOST_PASSWORD=YOUR_SMTP_PASSWORD_HERE
DEFAULT_FROM_EMAIL=ListDreams <noreply@listdreams.it>


# ── Next.js (frontend) ─────────────────────────────────────────
# Public API URL used by the browser (leave blank to use Next.js rewrites)
NEXT_PUBLIC_API_URL=
